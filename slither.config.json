# Slither Configuration for Smart Contract Security Analysis
# Reference: 02_MVP_IMPLEMENTATION_PLAN.md Phase 5

# Detectors to run
detectors_to_run = [
    # High priority detectors
    'reentrancy-eth',
    'reentrancy-no-eth',
    'reentrancy-benign',
    'reentrancy-events',
    'unchecked-transfer',
    'arbitrary-send-eth',
    'unchecked-lowlevel',
    'multiple-constructors',
    'suicidal',
    
    # Medium priority detectors
    'unused-state',
    'incorrect-equality',
    'constable-states',
    'calls-loop',
    'deprecated-standards',
    'uninitialized-state',
    'uninitialized-local',
    'missing-zero-check',
    'reentrancy-unlimited',
    
    # Low priority detectors
    'naming-convention',
    'similar-names',
    'unused-return',
    'shadowing-abstract',
    'shadowing-local',
    'shadowing-state',
    'too-many-digits',
    'external-function',
]

# Detectors to exclude
detectors_to_exclude = [
    'solc-version',  # We use specific version
    'low-level-calls',  # Required for ERC20 transfers
]

# Compilation settings
compile_force_framework = 'foundry'
solc = '0.8.20'

# Output settings
filter_paths = 'node_modules|test|scripts'
legacy_ast = false

# CI/CD settings
fail_on = 'high'
exclude_dependencies = true
