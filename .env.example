# DEPLOYMENT ENVIRONMENT VARIABLES
# ⚠️ NEVER COMMIT THIS FILE TO GIT! ⚠️

# Your deployer wallet private key (without 0x prefix)
PRIVATE_KEY=YOUR_PRIVATE_KEY_HERE

# PolygonScan API key (for contract verification - optional)
POLYGONSCAN_API_KEY=YOUR_POLYGONSCAN_API_KEY

# RPC URL (already configured in foundry.toml)
# RPC_URL=https://rpc-amoy.polygon.technology/

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# Database Type: sqlite (development) or postgresql (production)
# Default: sqlite (for development/MVP)
# Production: postgresql (Supabase recommended)
DATABASE_TYPE=sqlite

# SQLite Configuration (for development)
# Database file will be created at: backend/data/ujamaa.db
SQLITE_DB_PATH=data/ujamaa.db

# PostgreSQL Configuration (for production - Supabase)
# Setup guide: documentation/SUPABASE_SETUP.md
# Migration script: backend/migrate_to_supabase.py
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# PostgreSQL Connection Pool Settings
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================

# Environment: development, staging, production
ENVIRONMENT=development

# Debug Mode (disable in production)
DEBUG=True

# Secret Key for sessions (generate a strong random key for production)
SECRET_KEY=your-secret-key-change-in-production

# =============================================================================
# API SETTINGS
# =============================================================================

# API Host
API_HOST=0.0.0.0

# API Port
API_PORT=8000

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://ujamaa-de-fi-platform.vercel.app

# =============================================================================
# WALLET CONNECT (for frontend)
# =============================================================================

# WalletConnect Project ID (get from https://cloud.walletconnect.com)
VITE_WALLET_CONNECT_PROJECT_ID=your-walletconnect-project-id

# =============================================================================
# FEATURE FLAGS
# =============================================================================

# Enable Demo Mode (for presentations/testing)
DEMO_MODE=True

# Enable Transaction Simulation (no real blockchain interaction)
TRANSACTION_SIMULATION=True

# Enable 24h Compliance Window (for KYC/KYB approvals)
COMPLIANCE_24H_WINDOW=True
