{
  "buildCommand": "chmod +x node_modules/.bin/vite && npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/assets/(.*)", "destination": "/assets/$1" },
    { "source": "/(.*\\.[a-f0-9]{8}\\.(js|css|png|jpg|svg|woff2))", "destination": "/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
