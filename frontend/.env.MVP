# =============================================================================
# UJAMAA DEFI PLATFORM - MVP-2 TESTNET
# Frontend Environment Configuration
# =============================================================================
# IMPORTANT: This is for TESTNET only. No real funds.
# Network: Polygon Amoy (Chain ID: 80002)
# =============================================================================

# -----------------------------------------------------------------------------
# MVP MODE FLAGS
# -----------------------------------------------------------------------------
VITE_IS_MVP=true
VITE_MVP_TESTNET=true

# -----------------------------------------------------------------------------
# NETWORK CONFIGURATION
# -----------------------------------------------------------------------------
VITE_NETWORK_NAME=polygon-amoy
VITE_CHAIN_ID=80002
VITE_RPC_URL=https://rpc-amoy.polygon.technology/
VITE_BLOCK_EXPLORER=https://amoy.polygonscan.com/

# -----------------------------------------------------------------------------
# MOCK SERVICE FLAGS
# -----------------------------------------------------------------------------
VITE_MOCK_BANK=true
VITE_MOCK_ESCROW=true
VITE_MOCK_GDIZ=true
VITE_MOCK_FIAT_RAMP=true
VITE_MOCK_KYB=true

# -----------------------------------------------------------------------------
# SMART CONTRACT ADDRESSES (Update post-deployment)
# -----------------------------------------------------------------------------
VITE_CONTRACT_UPT_TOKEN=
VITE_CONTRACT_LIQUIDITY_POOL=
VITE_CONTRACT_MOCK_ESCROW=
VITE_CONTRACT_MOCK_FIAT_RAMP=
VITE_CONTRACT_JURISDICTION_COMPLIANCE=

# -----------------------------------------------------------------------------
# API CONFIGURATION
# -----------------------------------------------------------------------------
VITE_API_URL=http://localhost:8000
VITE_API_VERSION=v2
VITE_API_RATE_LIMIT_PUBLIC=100
VITE_API_RATE_LIMIT_AUTHENTICATED=1000

# -----------------------------------------------------------------------------
# INVESTMENT LIMITS (Testnet, in UJEUR)
# -----------------------------------------------------------------------------
VITE_MAX_DEPOSIT=1000000
VITE_MIN_DEPOSIT=1000
VITE_DAILY_WITHDRAWAL_LIMIT=500000
VITE_INSTITUTIONAL_MIN=100000
VITE_RETAIL_MAX=50000

# -----------------------------------------------------------------------------
# FX CONFIGURATION
# -----------------------------------------------------------------------------
VITE_UJEUR_EUR_PARITY=1.0
VITE_EUR_FCFA_RATE=655.957
VITE_FX_FEE_INVESTMENT=0.02
VITE_FX_FEE_REPAYMENT=0.02

# -----------------------------------------------------------------------------
# YIELD CONFIGURATION
# -----------------------------------------------------------------------------
VITE_YIELD_MANAGEMENT_FEE=0.02
VITE_YIELD_PERFORMANCE_FEE=0.20
VITE_YIELD_HURDLE_RATE=0.05

# -----------------------------------------------------------------------------
# COMPLIANCE CONFIGURATION
# -----------------------------------------------------------------------------
VITE_KYB_THRESHOLD_EUR=100000
VITE_BLOCKED_JURISDICTIONS=KP,IR,SY,CU,MM,BY,RU,VE,SD,YE,ML,BF
VITE_ALLOWED_AFRICAN_MARKETS=NG,KE,ZA,GH,MU,CI,SN,TG,BJ
VITE_ALLOWED_INTERNATIONAL=EU,UK,UAE,SG,US

# -----------------------------------------------------------------------------
# FEATURE FLAGS
# -----------------------------------------------------------------------------
VITE_FEATURE_P0_CORE=true
VITE_FEATURE_P1_ENHANCEMENTS=true
VITE_FEATURE_P2_OPTIONAL=false

# -----------------------------------------------------------------------------
# DEMO MODE
# -----------------------------------------------------------------------------
VITE_DEMO_ENABLED=true
VITE_DEMO_INSTITUTIONAL_BALANCE=10000000
VITE_DEMO_RETAIL_BALANCE=50000
VITE_DEMO_ORIGINATOR_BALANCE=1000000

# -----------------------------------------------------------------------------
# DISCLAIMER TEXT
# -----------------------------------------------------------------------------
VITE_DISCLAIMER_HEADER=🚀 MVP: Institutional Architecture - Testnet Release
VITE_DISCLAIMER_FOOTER=This is a testnet deployment. No real funds are handled.

# -----------------------------------------------------------------------------
# WALLET CONFIGURATION
# -----------------------------------------------------------------------------
VITE_WALLET_CONNECT_PROJECT_ID=your_wallet_connect_project_id
VITE_SUPPORTED_WALLETS=metaMask,rainbow,coinbase,walletConnect

# -----------------------------------------------------------------------------
# ANALYTICS & MONITORING (Optional)
# -----------------------------------------------------------------------------
VITE_SENTRY_DSN=
VITE_POSTHOG_API_KEY=
VITE_ENABLE_ANALYTICS=false

# -----------------------------------------------------------------------------
# DEVELOPMENT
# -----------------------------------------------------------------------------
VITE_LOG_LEVEL=debug
VITE_ENABLE_DEV_TOOLS=true
